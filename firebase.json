{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "app.py",
      "build_data.py",
      "constitution.pdf",
      "vapi_env/**",
      "__pycache__/**",
      ".env",
      "templates/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}